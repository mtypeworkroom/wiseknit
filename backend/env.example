# WiseKnit Backend — Environment Variables
# Copy this file to .env and fill in your values

# AI Provider Keys (user provides their own)
# These are set per-request from the frontend, not stored here
# For local testing you can set defaults:
HF_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# CORS — frontend URL
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development
